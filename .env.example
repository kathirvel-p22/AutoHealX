# AutoHealX Environment Configuration

# Application Settings
VITE_APP_NAME=AutoHealX
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Advanced System Monitoring & Healing Platform

# API Configuration (if needed)
VITE_API_URL=http://localhost:3001
VITE_API_TIMEOUT=10000

# Firebase Configuration (optional)
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# Development Settings
VITE_DEV_MODE=true
VITE_DEBUG_MODE=false

# Performance Settings
VITE_MONITORING_INTERVAL=3000
VITE_CHART_UPDATE_INTERVAL=2000
VITE_HEALTH_CHECK_INTERVAL=5000

# Security Settings
VITE_SESSION_TIMEOUT=3600000
VITE_MAX_LOGIN_ATTEMPTS=5
VITE_PAIRING_CODE_EXPIRY=300000

# Feature Flags
VITE_ENABLE_REAL_SYSTEM_MONITORING=true
VITE_ENABLE_MULTILINGUAL=true
VITE_ENABLE_THEME_SWITCHING=true
VITE_ENABLE_DEVICE_PAIRING=true