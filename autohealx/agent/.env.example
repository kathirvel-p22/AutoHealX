# AutoHealX Agent Environment Variables
# Copy this file to .env and fill in your values

# Healing Mode: 'suggestion' (safe) or 'auto' (autonomous)
HEAL_MODE=suggestion

# Firebase Project ID (if not using service account file)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Monitoring interval in ms (default: 3000 = 3 seconds)
MONITOR_INTERVAL_MS=3000
