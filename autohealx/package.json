{
  "name": "autohealx",
  "version": "1.0.0",
  "description": "AutoHealX — Intelligent Self-Healing System Monitor",
  "scripts": {
    "start": "node start-autohealx.js",
    "start:dev": "concurrently \"npm run agent\" \"npm run dashboard\"",
    "agent": "cd agent && node index.js",
    "dashboard": "cd dashboard && npm start",
    "install:all": "cd agent && npm install && cd ../dashboard && npm install",
    "build": "cd dashboard && npm run build"
  },
  "keywords": [
    "self-healing",
    "monitoring",
    "system",
    "autohealx"
  ],
  "author": "AutoHealX Team",
  "license": "MIT",
  "main": "start-autohealx.js",
  "type": "commonjs",
  "dependencies": {
    "chalk": "^5.6.2",
    "concurrently": "^9.2.1"
  }
}
